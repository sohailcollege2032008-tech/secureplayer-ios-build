# Regenerated by `flutter pub get` — never hand-edit, never commit machine-
# specific paths from whoever's Mac this gets built on.
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.metadata
build/

# Regenerated by `flutter pub get` + `cd ios && pod install` — contains
# absolute paths to the local Flutter SDK, must not be shared across
# machines. NOTE: ios/Flutter/Debug.xcconfig, Release.xcconfig, and
# AppFrameworkInfo.plist are static templates Xcode's build system requires
# directly (baseConfigurationReference) — they are NOT machine-specific and
# ARE tracked; only Generated.xcconfig and ephemeral/ are excluded here.
ios/Flutter/Generated.xcconfig
ios/Flutter/ephemeral/
ios/Flutter/flutter_export_environment.sh
ios/Pods/
ios/.symlinks/
ios/Podfile.lock

*.iml
.idea/
