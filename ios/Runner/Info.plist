<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Secure Player</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>secure_player</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<!-- Encryption use is limited to the exempt categories: standard TLS/HTTPS
	     (cert_pinning_service.dart) and standard, non-authored algorithms
	     (AES-128-CBC, AES-256-GCM, HKDF-SHA256) used solely for video
	     copy-protection/DRM — both exempt under EAR, no export documentation
	     required. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<!-- file_picker and webview_flutter link photo-library/camera/location
	     capable code on iOS even though this app never actually invokes
	     those capabilities itself — Apple's automated binary scan flags any
	     linked capability regardless of whether app logic calls it, and
	     rejects the build without a matching usage string. Descriptions
	     below are written to be honest about that (no camera capture, no
	     location feature, no profile photo upload anywhere in this app),
	     rather than describing features that don't exist. -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>يستخدم التطبيق منتقي الملفات لاختيار واستيراد ملف الكورس (.sec) من جهازك.</string>
	<key>NSCameraUsageDescription</key>
	<string>لا يستخدم التطبيق الكاميرا مباشرة، لكن المتصفح المدمج بداخله قد يطلب هذا الإذن إذا تطلب أحد المحتويات المعروضة ذلك.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>لا يستخدم التطبيق تحديد الموقع مباشرة، لكن المتصفح المدمج بداخله قد يطلب هذا الإذن إذا تطلب أحد المحتويات المعروضة ذلك.</string>
</dict>
</plist>
